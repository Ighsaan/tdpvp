{
  "name": "@tdpvp/client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:shared": "npm run build --prefix ../../packages/shared",
    "dev:desktop:web": "npm run build:shared && vite --host 0.0.0.0 --port 5173",
    "build:desktop:web": "npm run build:shared && npm run build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:ci": "tauri build --no-bundle --ci",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tauri-apps/plugin-process": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.0.0",
    "@tdpvp/shared": "file:../../packages/shared",
    "colyseus.js": "^0.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@types/node": "^20.17.57",
    "@types/three": "^0.182.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
